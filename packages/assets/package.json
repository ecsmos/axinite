{
  "name": "@axinite/assets",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.mjs",
      "require": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@gltf-transform/core": "latest",
    "@gltf-transform/functions": "latest",
    "comlink": "latest",
    "opentype.js": "latest",
    "msdfgen-wasm": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/opentype.js": "^1.3.9",
    "bun-types": "^1.3.11",
    "tsup": "latest",
    "typescript": "latest"
  }
}
