{
  "name": "gltf-ecs",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "gltf-ecs": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "process": "bun src/cli.ts"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "bitecs": "^0.4.0",
    "draco3dgltf": "^1.5.7",
    "fs-extra": "^11.3.4",
    "ktx2-encoder": "^0.5.1",
    "meshoptimizer": "^1.1.0",
    "mikktspace": "^1.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/fs-extra": "^11.0.4",
    "bun-types": "^1.3.11",
    "@types/draco3dgltf": "^1.4.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist",
    "src"
  ]
}
