{
  "name": "@axinite/gltf-processor-ecs",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "process": "bun src/cli.ts"
  },
  "bin": {
    "gltf-ecs": "./dist/cli.js"
  },
  "dependencies": {
    "@gltf-transform/core": "latest",
    "@gltf-transform/extensions": "latest",
    "@gltf-transform/functions": "latest",
    "fs-extra": "latest",
    "sharp": "latest",
    "draco3dgltf": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/fs-extra": "latest",
    "@types/bun": "latest",
    "@types/draco3dgltf": "latest",
    "tsup": "latest",
    "typescript": "latest"
  }
}
