{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@axinite/utils": ["packages/utils/src/index.ts"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"]
}
